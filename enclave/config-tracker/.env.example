# Required environment variables for config-tracker
# All variables are REQUIRED - the application will fail to start if any are missing

# Capabilities registry address (hex string, with or without 0x prefix)
CAP_REG_ADDR=0x1234567890123456789012345678901234567890

# Chain ID (string representation of integer) - REQUIRED
CHAIN_ID=1

# DON ID (string representation of uint32) - REQUIRED
DON_ID=1

# Master public key (hex string) - REQUIRED.
INITIAL_MASTER_PUBLIC_KEY_

# Threshold - REQUIRED.
INITIAL_T=5

# Host port (string) - REQUIRED
HOST_PORT=8081

# RPC node configuration (JSON marshalled string) - REQUIRED
NODE_CONFIG='[{"name":"node1","wsURL":"ws://node1.test","httpURL":"http://node1.test"},{"name":"node2","wsURL":"ws://node2.test","httpURL":"http://node2.test"}]'